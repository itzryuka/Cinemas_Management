@model IEnumerable<BAO_Cinemas.Models.Showtime>

@{
    var movie = ViewBag.MovieInfo as BAO_Cinemas.Models.Movie;
    ViewData["Title"] = $"Lịch Chiếu: {movie?.Title}";
}

<div class="container-fluid bg-dark text-white p-4 mt-4 rounded shadow">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <h2 class="fw-bold text-warning m-0">
            <i class="bi bi-clock-history"></i> Lịch Chiếu: <span class="text-info">@movie?.Title</span>
        </h2>

        <div>
            <a asp-action="Showtime" class="btn btn-outline-light">
                <i class="bi bi-arrow-left"></i> Về Danh sách Phim
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-dark table-hover table-bordered align-middle text-center">
            <thead class="table-secondary text-dark">
                <tr>
                    <th style="width: 15%;">Ngày chiếu</th>
                    <th style="width: 15%;">Khung giờ</th>
                    <th style="width: 25%;">Địa điểm (Rạp - Phòng)</th>
                    <th style="width: 15%;">Giá vé</th>
                    <th style="width: 15%;">Tình trạng ghế</th>
                    <th style="width: 15%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        // Logic đếm số ghế đã đặt (Cắt chuỗi BookedSeats bằng dấu phẩy)
                        int bookedCount = string.IsNullOrEmpty(item.BookedSeats) ? 0 : item.BookedSeats.Split(',').Length;
                        int emptySeats = item.Room.TotalSeats - bookedCount;

                        <tr>
                            <td class="fw-bold fs-5 text-warning">@item.StartTime.ToString("dd/MM/yyyy")</td>

                            <td class="fw-bold">
                                @item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")
                            </td>

                            <td class="text-start">
                                <span class="text-info fw-bold">@item.Cinema.Name</span><br>
                                <small class="text-secondary"><i class="bi bi-door-open"></i> @item.Room.Name</small>
                            </td>

                            <td class="text-success fw-bold">@item.Price.ToString("N0") đ</td>

                            <td>
                                @if (bookedCount == 0)
                                {
                                    <span class="badge bg-secondary px-2 py-1">Trống hoàn toàn</span>
                                }
                                else if (emptySeats == 0)
                                {
                                    <span class="badge bg-danger px-2 py-1">Hết vé</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary px-2 py-1">Đã đặt @bookedCount/@item.Room.TotalSeats</span>
                                }
                            </td>

                            <td>
                                @if (bookedCount == 0)
                                {
                                    <a asp-action="DeleteShowtime" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bạn có chắc chắn muốn hủy suất chiếu này?');"
                                       title="Hủy suất chiếu">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary disabled" title="Không thể xóa vì đã có khách đặt vé">
                                        <i class="bi bi-lock-fill"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">
                            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                            Phim này đã hết lịch chiếu.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>